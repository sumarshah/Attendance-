POSTGRES_DB=attendance_db
POSTGRES_USER=attendance_user
POSTGRES_PASSWORD=change_this_strong_password
FRONTEND_ORIGIN=http://your-vps-ip
APP_PORT=80

# Device punch mode (recommended)
DEVICE_PUNCH_MODE=BIOMETRIC_ONLY

# Auth (JWT) - must be strong in production
JWT_SECRET=__SET_A_LONG_RANDOM_SECRET_64_CHARS_MIN__
JWT_EXPIRES_IN=7d

# Seed admin user (created on first boot if missing)
ADMIN_EMAIL=admin@rcc.local
ADMIN_PASSWORD=__SET_A_STRONG_ADMIN_PASSWORD__
ADMIN_NAME=RCC Admin
